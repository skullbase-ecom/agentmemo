{
  "name": "agentmemo",
  "version": "1.0.0",
  "description": "AgentMemo — an Agent Memory API on Cloudflare Workers (Hono + D1 + KV)",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:schema:local": "wrangler d1 execute agentmemo-db --local --file=./schema.sql",
    "db:schema:remote": "wrangler d1 execute agentmemo-db --remote --file=./schema.sql",
    "db:seed:local": "wrangler d1 execute agentmemo-db --local --file=./seed.sql",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.101.0"
  }
}
